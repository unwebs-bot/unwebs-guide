---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}
interface Props {
	headings: Heading[];
}
const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<aside class="toc">
	<p class="toc-title">목차</p>
	<ul>
		{filtered.map((h) => (
			<li>
				<a href={`#${h.slug}`} class:list={[{ 'toc-h3': h.depth === 3 }]}>
					{h.text}
				</a>
			</li>
		))}
	</ul>
	<a href="https://unwebs.co.kr/contact/" class="toc-cta" target="_blank" rel="noopener">
		<svg class="toc-cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
			<polyline points="14 2 14 8 20 8" />
			<line x1="16" y1="13" x2="8" y2="13" />
			<line x1="16" y1="17" x2="8" y2="17" />
			<line x1="10" y1="9" x2="8" y2="9" />
		</svg>
		프로젝트 문의
	</a>
</aside>

<script>
	const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc a[href^="#"]');
	const sections = Array.from(tocLinks)
		.map((a) => {
			const id = a.getAttribute('href')?.slice(1);
			return id ? document.getElementById(id) : null;
		})
		.filter((el): el is HTMLElement => Boolean(el));

	function updateToc() {
		let activeId: string | null = null;
		const threshold = 100;
		for (const sec of sections) {
			const rect = sec.getBoundingClientRect();
			if (rect.top - threshold <= 0) activeId = sec.id;
		}
		tocLinks.forEach((a) => {
			a.classList.toggle('active', a.getAttribute('href') === '#' + activeId);
		});
	}
	window.addEventListener('scroll', updateToc, { passive: true });
	updateToc();
</script>
