---
import { sections } from '../data/sidebar';

interface Props {
	currentSlug?: string;
}
const { currentSlug = '' } = Astro.props;

const activeSectionLabel =
	sections.find((s) => s.groups.some((g) => g.items.some((i) => i.slug === currentSlug)))
		?.label ?? sections[0].label;
---

<aside class="sidebar">
	{sections.map((section) => (
		<details class="sidebar-section" open={section.label === activeSectionLabel}>
			<summary class="sidebar-title">
				<span>{section.label}</span>
				<span class="section-arrow">▾</span>
			</summary>
			<div class="sidebar-section-body">
				{section.groups.map((group) => (
					<div class="sidebar-group">
						<div class="sidebar-group-label">{group.label}</div>
						<ul class="sidebar-sub">
							{group.items.map((item) => (
								<li>
									<a
										href={`/guides/${item.slug}/`}
										class:list={[{ active: currentSlug === item.slug }]}
									>
										{item.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</details>
	))}
</aside>
