---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Toc from '../components/Toc.astro';
import { sections } from '../data/sidebar';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}
interface Faq {
	q: string;
	a: string;
}
interface Props {
	title: string;
	description?: string;
	slug: string;
	headings: Heading[];
	faqs?: Faq[];
}
const { title, description, slug, headings, faqs = [] } = Astro.props;

const section = sections.find((s) =>
	s.groups.some((g) => g.items.some((i) => i.slug === slug))
);
const group = section?.groups.find((g) => g.items.some((i) => i.slug === slug));
const itemLabel = group?.items.find((i) => i.slug === slug)?.label ?? title;

const site = Astro.site ?? new URL('https://guide.unwebs.co.kr');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL('/unwebs-logo.png', site).href;

const breadcrumb = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: '가이드센터', item: site.href },
		{ '@type': 'ListItem', position: 2, name: itemLabel, item: canonical },
	],
};
const article = {
	'@context': 'https://schema.org',
	'@type': 'TechArticle',
	headline: title,
	description: description ?? '',
	inLanguage: 'ko',
	url: canonical,
	author: { '@type': 'Organization', name: '언웹스' },
	publisher: {
		'@type': 'Organization',
		name: '언웹스',
		logo: { '@type': 'ImageObject', url: ogImage },
	},
};
const faqPage =
	faqs.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: faqs.map((f) => ({
					'@type': 'Question',
					name: f.q,
					acceptedAnswer: { '@type': 'Answer', text: f.a },
				})),
			}
		: null;
const schemas = [breadcrumb, article, ...(faqPage ? [faqPage] : [])];
---

<BaseLayout title={`${title} — 언웹스 가이드센터`} description={description} schemas={schemas}>
	<Header section={section?.label ?? '가이드센터'} />
	<div class="layout">
		<Sidebar currentSlug={slug} />
		<main class="main">
			<div class="main-inner">
				<nav class="breadcrumb">
					<a href="/">가이드센터</a>
					{section && (
						<>
							<span class="sep">›</span>
							<a href="/">{section.label}</a>
						</>
					)}
					{group && (
						<>
							<span class="sep">›</span>
							<span>{group.label}</span>
						</>
					)}
					<span class="sep">›</span>
					<span>{itemLabel}</span>
				</nav>

				<article class="article">
					<h1>{title}</h1>
					<slot />
					<footer class="article-footer">
						작성·운영 — <strong>언웹스 가이드센터</strong>. 실무에서 검증한 내용을 정리하고 정기적으로 업데이트합니다. <a href="/about/">가이드센터 소개 →</a>
					</footer>
				</article>
			</div>
		</main>
		<Toc headings={headings} />
	</div>
</BaseLayout>
