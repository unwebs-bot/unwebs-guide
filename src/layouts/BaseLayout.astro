---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	schemas?: object[];
}
const {
	title,
	description = '기업·병원·소개형 홈페이지 운영자를 위한 실무 가이드.',
	schemas = [],
} = Astro.props;

const site = Astro.site ?? new URL('https://guide.unwebs.co.kr');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL('/unwebs-logo.png', site).href;

const organization = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: '언웹스',
	url: site.href,
	logo: ogImage,
};
const allSchemas = [organization, ...schemas];
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="언웹스 가이드센터" />
		<meta property="og:locale" content="ko_KR" />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.css"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		{
			allSchemas.map((s) => (
				<script type="application/ld+json" set:html={JSON.stringify(s)} />
			))
		}
	</head>
	<body>
		<slot />
	</body>
</html>
