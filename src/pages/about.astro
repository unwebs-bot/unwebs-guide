---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';

const site = Astro.site ?? new URL('https://guide.unwebs.co.kr');
const aboutSchema = {
	'@context': 'https://schema.org',
	'@type': 'AboutPage',
	name: '가이드센터 소개',
	url: new URL('/about/', site).href,
	inLanguage: 'ko',
	isPartOf: {
		'@type': 'WebSite',
		name: '언웹스 가이드센터',
		url: site.href,
	},
};
---

<BaseLayout
	title="가이드센터 소개 — 언웹스 가이드센터"
	description="언웹스 가이드센터의 운영 주체·작성 방식·목적 안내. 홈페이지 제작·운영 실무를 정리한 문서 모음입니다."
	schemas={[aboutSchema]}
>
	<Header section="소개" />
	<div class="layout">
		<Sidebar />
		<main class="main">
			<div class="main-inner">
				<article class="article">
					<h1>가이드센터 소개</h1>
					<blockquote>
						<p>
							언웹스 가이드센터는 홈페이지 제작·운영 실무를 정리한 문서 모음입니다. 아임웹·WordPress·SEO·AEO·기획까지, 직접 다루며 부딪힌 문제와 해법을 기록합니다.
						</p>
					</blockquote>

					<h2>무엇을 다루나요</h2>
					<p>
						홈페이지를 직접 운영하다 보면 도메인 연결, SSL, 메뉴 수정, 검색 노출, 폼 설정처럼 막히는 지점이 생깁니다. 가이드센터는 그런 실무 문제를 카테고리별로 정리합니다.
					</p>
					<ul>
						<li><strong>아임웹 운영</strong> — 도메인·디자인·마케팅 등 운영 실무</li>
						<li><strong>WordPress 운영</strong> — 설치·테마·플러그인·보안·속도</li>
						<li><strong>SEO · AEO</strong> — 검색·AI 답변 노출 전략</li>
						<li><strong>기획 & 디자인</strong> — 정보 구조·디자인 시스템·카피·전환</li>
					</ul>

					<h2>어떻게 작성하나요</h2>
					<p>
						실제 작업 경험과 검색엔진·플랫폼의 공식 문서, 검증된 자료를 바탕으로 작성합니다. 변화가 빠른 SEO·AI 검색 영역은 기준이 바뀔 때마다 점검하고 정기적으로 업데이트합니다. 한 번 쓰고 방치하지 않는 것을 원칙으로 합니다.
					</p>

					<h2>왜 만드나요</h2>
					<p>
						홈페이지는 한 번 만들고 끝이 아니라 계속 운영해야 하는 자산입니다. 운영자가 스스로 문제를 해결하고, 더 나은 결정을 내리는 데 도움이 되도록 — 막연한 일반론이 아니라 실제로 쓰이는 방법을 정리합니다.
					</p>

					<h2>누가 운영하나요</h2>
					<p>
						웹사이트 제작·운영을 하는 <strong>언웹스</strong>가 작성하고 운영합니다.
					</p>

					<footer class="article-footer">
						문의는 <a href="mailto:contact@unwebs.co.kr">contact@unwebs.co.kr</a> 로 주세요.
					</footer>
				</article>
			</div>
		</main>
		<aside class="toc"></aside>
	</div>
</BaseLayout>
