---
import { getCollection, render } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

export async function getStaticPaths() {
	const guides = await getCollection('guides');
	return guides.map((guide) => ({
		params: { slug: guide.id.replace(/\.md$/, '') },
		props: { guide },
	}));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);
const slug = guide.id.replace(/\.md$/, '');

function parseFaqs(body: string): { q: string; a: string }[] {
	const faqs: { q: string; a: string }[] = [];
	const re = /\*\*Q\.\s*(.+?)\*\*\s*\n+A\.\s*(.+?)(?=\n\n|\n\*\*Q\.|\n##|\n---|$)/gs;
	let m: RegExpExecArray | null;
	while ((m = re.exec(body)) !== null) {
		const q = m[1].trim();
		const a = m[2]
			.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
			.replace(/\*\*([^*]+)\*\*/g, '$1')
			.replace(/`([^`]+)`/g, '$1')
			.replace(/\s+/g, ' ')
			.trim();
		if (q && a) faqs.push({ q, a });
	}
	return faqs;
}
const faqs = parseFaqs(guide.body ?? '');
---

<GuideLayout
	title={guide.data.title}
	description={guide.data.description}
	slug={slug}
	headings={headings}
	faqs={faqs}
>
	<Content />
</GuideLayout>
